# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# --- Airtable -----------------------------------------------------------------
# Personal Access Token. Create one at https://airtable.com/create/tokens
# Required scopes:
#   - data.records:read
#   - data.records:write
#   - schema.bases:read
# Access: select only your production-manager base.
AIRTABLE_PAT=

# Base ID. Open your base in the browser; the URL is
# https://airtable.com/<BASE_ID>/...   The ID starts with "app".
AIRTABLE_BASE_ID=

# --- Auth ---------------------------------------------------------------------
# Login accounts live in the "App Users" Airtable table (email + role +
# salted password hash), managed from the in-app Users screen by an admin.
# There is no shared passcode.

# Random 32+ char string used to sign session cookies.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# --- Weather overlay (optional) -----------------------------------------------
# The Schedule view's weather toggle pulls a metro-wide forecast from Open-Meteo
# (free, no API key). Defaults to Oklahoma City; override only if the service
# area moves. All four are optional.
# WEATHER_LAT=35.4676
# WEATHER_LON=-97.5164
# WEATHER_TIMEZONE=America/Chicago
# WEATHER_LOCATION_NAME=Oklahoma City, OK
