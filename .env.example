# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# --- Airtable -----------------------------------------------------------------
# Personal Access Token. Create one at https://airtable.com/create/tokens
# Required scopes:
#   - data.records:read
#   - data.records:write
#   - schema.bases:read
# Access: select only your production-manager base.
AIRTABLE_PAT=

# Base ID. Open your base in the browser; the URL is
# https://airtable.com/<BASE_ID>/...   The ID starts with "app".
AIRTABLE_BASE_ID=

# --- Auth ---------------------------------------------------------------------
# Shared passcode that any office staff types into the login screen.
# Pick something memorable but not trivial; rotate by changing this and redeploying.
ADMIN_PASSCODE=

# Random 32+ char string used to sign session cookies.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# --- Paint Scout (not yet used) -------------------------------------------------
# API key for Paint Scout (estimating software). Reserved for a future feature
# to pull quote/proposal data into the app. No code reads this yet.
# Note the exact casing: PaintScout_API_Key (matches the Vercel env var).
PaintScout_API_Key=
