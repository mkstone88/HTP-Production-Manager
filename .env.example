# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# --- Airtable -----------------------------------------------------------------
# Personal Access Token. Create one at https://airtable.com/create/tokens
# Required scopes:
#   - data.records:read
#   - data.records:write
#   - schema.bases:read
# Access: select only your production-manager base.
AIRTABLE_PAT=

# Base ID. Open your base in the browser; the URL is
# https://airtable.com/<BASE_ID>/...   The ID starts with "app".
AIRTABLE_BASE_ID=

# --- Auth ---------------------------------------------------------------------
# Login accounts live in the "App Users" Airtable table (email + role +
# salted password hash), managed from the in-app Users screen by an admin.
# There is no shared passcode.

# Random 32+ char string used to sign session cookies.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# --- PaintScout (optional) ----------------------------------------------------
# Powers the weekly scorecard's $ Invoiced / $ Collected columns and the
# proposal reconciliation sweep. v2 API key from PaintScout.
PaintScout_API_Key=

# --- GoHighLevel / LeadConnector (optional) -----------------------------------
# Powers the "missed leads" reconciliation sweep + nightly lead backfill.
GHL_API_Token=
GHL_Location_ID=

# --- Cron (optional) ----------------------------------------------------------
# Shared secret for the nightly reconciliation crons (see vercel.json). Vercel
# Cron sends it as `Authorization: Bearer <CRON_SECRET>`; reconcile endpoints
# also accept a signed-in Office Admin/Admin session for manual runs.
CRON_SECRET=
